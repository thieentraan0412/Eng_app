{
  "name": "engmaster",
  "version": "0.1.0",
  "description": "Ứng dụng học tiếng Anh - EngMaster (Electron + React + TypeScript + Supabase)",
  "main": "dist-electron/main.js",
  "author": "",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "dist": "npm run build && electron-builder --win"
  },
  "build": {
    "appId": "com.engmaster.app",
    "productName": "EngMaster",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist",
      "dist-electron",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "EngMaster"
    }
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@fontsource/lora": "^5.2.8",
    "@supabase/supabase-js": "^2.45.4",
    "dictionary-en": "^4.0.0",
    "nspell": "^2.1.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^32.1.2",
    "electron-builder": "^25.0.5",
    "typescript": "^5.5.4",
    "vite": "^5.4.6",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "allowScripts": {
    "electron@32.3.3": true,
    "esbuild@0.21.5": true
  }
}
